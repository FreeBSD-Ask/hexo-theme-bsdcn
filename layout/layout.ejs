<!DOCTYPE html>
<html lang="<%= config.language || 'en' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title || config.title %></title>
  <meta name="description" content="<%= page.description || config.description %>">
  <link rel="stylesheet" href="<%= url_for('css/style.css') %>">
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="container">
      <div class="header-content">
        <a href="<%= url_for('/') %>" class="logo">
          <img src="<%= url_for(theme.site.logo) %>" alt="<%= theme.site.title %>">
        </a>
        <nav class="main-nav">
          <ul>
            <% for (let item of theme.nav.items) {%>
            <li><a href="<%= url_for(item.link) %>"><%= item.text %></a></li>
            <% } %>
          </ul>
        </nav>
        <div class="language-selector">
          <ul>
            <% for (let lang of theme.language.available) {%>
            <li><a href="#" class="<%= lang === theme.language.default ? 'active' : '' %>"><%= lang %></a></li>
            <% } %>
          </ul>
        </div>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1><%= theme.site.title %></h1>
        <p><%= theme.site.description %></p>
        <div class="hero-buttons">
          <a href="<%= url_for('/about/') %>" class="btn btn-primary">Learn More</a>
          <a href="<%= url_for('/download/') %>" class="btn btn-secondary">Download FreeBSD</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <main class="main">
    <div class="container">
      <div class="main-content">
        <!-- Left Sidebar -->
        <aside class="sidebar left-sidebar">
          <div class="sidebar-section">
            <h3>New to FreeBSD?</h3>
            <ul>
              <li><a href="<%= url_for('/getting-started/') %>">Getting Started</a></li>
              <li><a href="<%= url_for('/documentation/') %>">Documentation</a></li>
              <li><a href="<%= url_for('/tutorials/') %>">Tutorials</a></li>
            </ul>
          </div>
          
          <div class="sidebar-section">
            <h3>Download FreeBSD</h3>
            <ul>
              <li><a href="<%= url_for('/download/') %>">Latest Release</a></li>
              <li><a href="<%= url_for('/download/archives/') %>">Older Versions</a></li>
              <li><a href="<%= url_for('/download/snapshots/') %>">Snapshots</a></li>
            </ul>
          </div>
          
          <div class="sidebar-section">
            <h3>Supported Releases</h3>
            <ul>
              <li>Production: 15.0</li>
              <li>Production: 14.4</li>
              <li>Production: 14.3</li>
              <li>Legacy: 13.5</li>
              <li>Upcoming: 15.1</li>
            </ul>
            <a href="<%= url_for('/releases/') %>" class="link-more">Support Lifecycle</a>
          </div>
        </aside>

        <!-- Center Content -->
        <div class="content">
          <div class="content-section">
            <h2>LATEST NEWS</h2>
            <ul class="news-list">
              <li>
                <span class="date">2026-03-10</span>
                <a href="#">FreeBSD 14.4-RELEASE Available</a>
              </li>
              <li>
                <span class="date">2026-03-03</span>
                <a href="#">New committer: Laurent Chardon (ports)</a>
              </li>
              <li>
                <span class="date">2026-02-28</span>
                <a href="#">FreeBSD 14.4-RC1 Available</a>
              </li>
              <li>
                <span class="date">2026-02-22</span>
                <a href="#">October-December 2025 Status Report</a>
              </li>
              <li>
                <span class="date">2026-02-22</span>
                <a href="#">FreeBSD 14.4-BETA3 Available</a>
              </li>
            </ul>
            <a href="<%= url_for('/news/') %>" class="link-more">More</a>
          </div>

          <div class="content-section">
            <h2>UPCOMING EVENTS</h2>
            <ul class="events-list">
              <li>
                <span class="date">2026-03-19 - 2026-03-22</span>
                <a href="#">AsiaBSDCon 2026 (Taipei, Taiwan)</a>
              </li>
              <li>
                <span class="date">2026-05-09 - 2026-05-09</span>
                <a href="#">BSD-NL 2026 (Utrecht, The Netherlands)</a>
              </li>
              <li>
                <span class="date">2026-06-17 - 2026-06-20</span>
                <a href="#">BSDCan 2026 (Ottawa, Canada)</a>
              </li>
              <li>
                <span class="date">2026-09-09 - 2026-09-13</span>
                <a href="#">EuroBSDCon 2026 (Brussels, Belgium)</a>
              </li>
            </ul>
            <a href="<%= url_for('/events/') %>" class="link-more">More</a>
          </div>
        </div>

        <!-- Right Sidebar -->
        <aside class="sidebar right-sidebar">
          <div class="sidebar-section">
            <h3>Shortcuts</h3>
            <ul>
              <% for (let link of theme.footer.links) {%>
              <li><a href="<%= url_for(link.link) %>"><%= link.text %></a></li>
              <% } %>
            </ul>
          </div>
          
          <div class="sidebar-section">
            <h3>PRESS</h3>
            <ul class="press-list">
              <li>
                <span class="date">2025-12</span>
                <a href="#">The Register takes a look at FreeBSD 15</a>
              </li>
              <li>
                <span class="date">2025-11</span>
                <a href="#">FreeBSD Officially Supported in OCI Runtime Specification v1.3</a>
              </li>
              <li>
                <span class="date">2025-10</span>
                <a href="#">An introduction to OCI Containers on FreeBSD</a>
              </li>
            </ul>
            <a href="<%= url_for('/press/') %>" class="link-more">More</a>
          </div>
          
          <div class="sidebar-section">
            <h3>SECURITY ADVISORIES</h3>
            <ul class="security-list">
              <li>
                <span class="date">2026-02-24</span>
                <a href="#">FreeBSD-SA-26:05.route</a>
              </li>
              <li>
                <span class="date">2026-02-24</span>
                <a href="#">FreeBSD-SA-26:04.jail</a>
              </li>
              <li>
                <span class="date">2026-02-10</span>
                <a href="#">FreeBSD-SA-26:03.blocklistd</a>
              </li>
            </ul>
            <a href="<%= url_for('/security/') %>" class="link-more">More</a>
          </div>
          
          <div class="sidebar-section">
            <h3>ERRATA NOTICES</h3>
            <ul class="errata-list">
              <li>
                <span class="date">2026-02-10</span>
                <a href="#">FreeBSD-EN-26:04.arm64</a>
              </li>
              <li>
                <span class="date">2026-01-27</span>
                <a href="#">FreeBSD-EN-26:03.vm</a>
              </li>
            </ul>
            <a href="<%= url_for('/errata/') %>" class="link-more">More</a>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3>About FreeBSD</h3>
          <p>FreeBSD is an operating system used to power modern servers, desktops, and embedded platforms.</p>
        </div>
        <div class="footer-section">
          <h3>Quick Links</h3>
          <ul>
            <% for (let link of theme.footer.links) {%>
            <li><a href="<%= url_for(link.link) %>"><%= link.text %></a></li>
            <% } %>
          </ul>
        </div>
        <div class="footer-section">
          <h3>Social</h3>
          <ul class="social-links">
            <% for (let social of theme.social) {%>
            <li><a href="<%= social.link %>"><%= social.icon %></a></li>
            <% } %>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; <%= new Date().getFullYear() %> The FreeBSD Project. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="<%= url_for('js/main.js') %>"></script>
</body>
</html>